# 비밀 (Secret Manager에 저장, git에 값 커밋 금지)
DB_PASSWORD=
TOKEN_PEPPER=
ORIGIN_ENC_KEY=
KAKAO_REST_KEY=
ODSAY_KEY=
TMAP_APP_KEY=

# 설정값 (비밀 아님, 운영/로컬 환경마다 값만 다름)
DB_URL=
DB_USERNAME=
CORS_ALLOWED_ORIGINS=https://yeondang.com,https://www.yeondang.com
# 승인된 Vercel Preview가 있으면 운영 .env에서 이 패턴을 보존한다.
CORS_ALLOWED_ORIGIN_PATTERNS=https://team-d-*.vercel.app
FRONTEND_BASE_URL=https://yeondang.com

# docker-compose.prod.yml (Traefik) 전용 공개 설정
API_DOMAIN=api.yeondang.com
ACME_EMAIL=
